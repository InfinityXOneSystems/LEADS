# Database
DATABASE_URL=postgresql://user:password@localhost:5432/leads_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password
FROM_EMAIL=noreply@xps-intelligence.com
FROM_NAME=XPS Intelligence Team

# APIs
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
HUNTER_IO_API_KEY=your_hunter_key
CLEARBIT_API_KEY=your_clearbit_key
GOOGLE_MAPS_API_KEY=your_google_maps_key

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Frontend URL
FRONTEND_URL=https://xps-intelligence.com

# Slack
SLACK_WEBHOOK_URL=your_slack_webhook

# XPS Intelligence sync
# Repositories (owner/repo format)
XPS_SYSTEM_REPO=InfinityXOneSystems/LEADS
XPS_FRONTEND_REPO=InfinityXOneSystems/frontend-system
# Branch where GitHub Pages are served from (gh-pages or docs)
XPS_PAGES_BRANCH=gh-pages

# GitHub App authentication (recommended – replaces the legacy PAT below)
# Create a GitHub App at https://github.com/settings/apps, grant it
# "Contents: Read & Write" and "Actions: Read & Write", then install it
# on the InfinityXOneSystems org.
GH_APP_ID=your_app_id
# Paste the full PEM content (including header/footer lines).
# In a .env file, replace newlines with \n:
#   GH_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GH_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# Optional – leave blank to auto-discover from the org (InfinityXOneSystems).
# Only needed if the App is installed on individual repos rather than the whole org.
GH_APP_INSTALLATION_ID=

# Legacy PAT fallback (used only when GitHub App is not configured above)
XPS_GITHUB_TOKEN=
